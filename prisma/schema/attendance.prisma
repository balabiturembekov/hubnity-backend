model AttendanceSchedule {
  id             String            @id @default(uuid())
  name           String
  startDate      DateTime
  repeatUntil    DateTime?
  repeatType     RepeatType        @default(NONE)
  organizationId String
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shifts         AttendanceShift[]

  @@index([organizationId])
  @@map("attendance_schedules")
}

model AttendanceShift {
  id            String             @id @default(uuid())
  dayOfWeek     Int?
  specificDate  DateTime?
  startTime     String
  endTime       String
  breakDuration Int
  scheduleId    String
  userId        String?
  schedule      AttendanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user          User?              @relation(fields: [userId], references: [id])

  @@map("attendance_shifts")
}

enum RepeatType {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}
