model Organization {
  id                  String               @id @default(uuid())
  name                String               @unique
  ownerId             String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  settings            Json?
  timezone            String               @default("UTC")
  currency            String               @default("USD")
  lockedPeriods       LockedPeriod[]
  attendanceSchedules AttendanceSchedule[]
  clients             Client[]
  holidays            Holiday[]
  invites             Invitation[]
  members             OrganizationMember[]
  owner               User                 @relation("Owner", fields: [ownerId], references: [id])
  projects            Project[]
  timeOffPolicies     TimeOffPolicy[]
  teamSize            TeamSize

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(uuid())
  role           MemberRole   @default(USER)
  status         MemberStatus @default(ACTIVE)
  hourlyRate     Float?
  weeklyLimit    Int?
  joinedAt       DateTime?
  invitedAt      DateTime?
  settings       Json?
  organizationId String
  userId         String
  invitedById    String
  valid_from     DateTime     @default(now())
  valid_to       DateTime?
  is_current     Boolean      @default(true)
  createdAt      DateTime     @default(now())
  invitedBy      User         @relation("Invitation", fields: [invitedById], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@map("organization_members")
}

model Holiday {
  id             String       @id @default(uuid())
  name           String
  date           DateTime
  recurring      Boolean      @default(false)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date, name])
  @@map("holidays")
}

enum MemberRole {
  OWNER
  ADMIN
  MANAGER
  USER
}

enum MemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum TeamSize {
  SIZE_1_2
  SIZE_3_6
  SIZE_7_10
  SIZE_11_50
  SIZE_51_250
  SIZE_251_500
  SIZE_500_PLUS
}
